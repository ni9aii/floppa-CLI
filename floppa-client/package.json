    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "json5": "^2.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "8.0.0-beta.16",
